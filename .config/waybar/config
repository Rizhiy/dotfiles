{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 1,
    "margin": 0,
    "modules-left": ["sway/mode", "sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "custom/weather",
        "pulseaudio",
        "backlight",
        "bluetooth",
        "custom/network",
        "memory",
        "cpu",
        "temperature",
        "custom/battery",
        "sway/language",
        "clock#date",
        "clock#time",
    ],
    "fixed-center": false,


    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}  {name}",
        "format-icons": {
            "1": "ï„ ",
            "2": "ï‰¨",
            "7": "ï†¶",
            "default": "ï„Œ",
        },
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "custom/weather": {
        "exec": "curl 'https://wttr.in/?format=1'",
        "interval": 3600,
        "format": "{}",
        "on-click": "kitty --hold curl wttr.in"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°ˆˆ",
            "deactivated": "َ°ˆ‰"
        },
        "tooltip": true
    },

    "clock#date": {
        "interval": 1,
        "format": "{:%Y-%m-%d}",
        "tooltip": false
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip": false
    },

    "cpu": {
        "format": "CPU {usage}%",
        "tooltip": true,
        "interval": 1,
        "on-click": "kitty htop -s PERCENT_CPU"
    },

    "memory": {
        "format": "RAM {}%",
        "interval": 1,
        "on-click": "kitty htop -s PERCENT_MEM"
    },

    "temperature": {
        "interval": 1,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["َ±ƒƒ", "َ°”ڈ", "َ±ƒ‚"],
        "tooltip": false,
    },

    "custom/battery": {
        "exec": "$HOME/.config/waybar/battery.sh",
        "interval": 5,
        "return-type": "json",
        "tooltip": false
    },

    "custom/network": {
        "exec": "$HOME/.config/waybar/network.sh",
        "interval": 1,
        "return-type": "json",
        "on-click": "kitty nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "َ°‚° {volume}%",
        "format-bluetooth-muted": "َ°‚² {icon}",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°¥°",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°„‌",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "sway/language": {
        "format": "ï„œ  {}",
        "min-length": 5,
        "on-click": "swaymsg 'input * xkb_switch_layout next'",
        "tooltip": false
    },

    "bluetooth": {
        "interval": 1,
        "format": "ïٹ”",
        "format-on": "ïٹ” on",
        "format-connected": "ïٹ” {num_connections}",
        "on-click": "kitty bluetui",
    }

}
